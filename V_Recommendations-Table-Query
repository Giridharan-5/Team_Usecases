CREATE TABLE `recommendations` (
  `id` int NOT NULL AUTO_INCREMENT,
  `vpu_id` int NOT NULL,
  `decision` varchar(50) DEFAULT NULL,
  `avg_usage` float DEFAULT NULL,
  `max_usage` float DEFAULT NULL,
  `forecasted_max` float DEFAULT NULL,
  `scale_percent` float DEFAULT NULL,
  `itis_ticket_number` varchar(100) DEFAULT NULL,
  `action_status` varchar(50) DEFAULT NULL,
  `remarks` text,
  `run_id` varchar(100) DEFAULT NULL,
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  KEY `fk_recommendations_vpu` (`vpu_id`),
  CONSTRAINT `fk_recommendations_vpu` FOREIGN KEY (`vpu_id`) REFERENCES `vm_primary_uri` (`vpu_id`)
) ENGINE=InnoDB AUTO_INCREMENT=2 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
